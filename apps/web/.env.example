# PaperBrief — Environment Variables
# Copy to .env.local and fill in values

# Supabase (from supabase.com project settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (from resend.com API keys)
RESEND_API_KEY=

# Stripe (from stripe.com dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenRouter (from openrouter.ai)
OPENROUTER_API_KEY=

# Cron secret (generate a random string)
CRON_SECRET=

# App URL
NEXT_PUBLIC_APP_URL=https://paperbrief.io
